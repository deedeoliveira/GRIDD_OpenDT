{
  "profileKey": "oswadt-ifc4-minimal-rdf-mapping",
  "version": "1.0.0",
  "description": "Declarative allowlist for the minimal OSWADT IFC4 model-version RDF projection.",
  "executionModel": "declarative_allowlist",
  "namespaces": {
    "bot": "https://w3id.org/bot#",
    "beo": "https://pi.pauwel.be/voc/buildingelement#",
    "prov": "http://www.w3.org/ns/prov#",
    "dcterms": "http://purl.org/dc/terms/",
    "project": "https://deedeoliveira.github.io/GRIDD_OpenDT/ontology/model-intake-v1#"
  },
  "includedIfcClasses": [
    "IfcProject",
    "IfcBuilding",
    "IfcBuildingStorey",
    "IfcSpace",
    "IfcFurnishingElement",
    "IfcBuildingElementProxy"
  ],
  "includedProperties": [
    "GlobalId",
    "Name",
    "LongName",
    "Tag",
    "SerialNumber",
    "Manufacturer",
    "Pset_SpaceCommon.Reference",
    "spatialContainment"
  ],
  "uriPatterns": {
    "logicalModel": "/model/{modelUuid}",
    "modelVersion": "/model-version/{modelVersionUuid}",
    "persistentSpace": "/space/{spaceUuid}",
    "persistentAsset": "/asset/{assetUuid}",
    "manifestation": "/model-version/{modelVersionUuid}/manifestation/{ifcGuid}",
    "materialisationActivity": "/activity/ifc-rdf-materialisation/{materialisationUuid}",
    "generatedGraph": "/graph/model-version/{modelVersionUuid}"
  },
  "rdfClasses": {
    "logicalModel": "project:LogicalModel",
    "modelVersion": "project:ModelVersion",
    "space": "bot:Space",
    "asset": "beo:Furnishing",
    "manifestation": "project:IfcManifestation",
    "activity": "prov:Activity",
    "sourceFile": "prov:Entity"
  },
  "predicates": [
    "dcterms:title",
    "dcterms:hasVersion",
    "prov:wasGeneratedBy",
    "prov:used",
    "prov:generated",
    "prov:specializationOf",
    "project:versionUuid",
    "project:versionNumber",
    "project:fileSha256",
    "project:ifcSchema",
    "project:ifcClass",
    "project:ifcGuid",
    "project:persistentUuid",
    "project:reference",
    "project:tag",
    "project:serialNumber",
    "project:manufacturer",
    "project:containedInSpace",
    "project:storeyLabel",
    "project:mappingProfileVersion",
    "project:idsProfileVersion"
  ],
  "identityRules": {
    "space": "Reuse SQL spaces.space_uuid resolved from Pset_SpaceCommon.Reference within the linked-model scope.",
    "asset": "Reuse SQL assets.asset_uuid resolved by the configured project identity provider; never use IFC GUID as persistent identity.",
    "manifestation": "Use a version-specific resource identified by model-version UUID plus IFC GUID and link with prov:specializationOf."
  },
  "provenanceRules": [
    "Record the source IFC hash and sanitized filename.",
    "Record the governed mapping artifact and the IDS source metadata.",
    "Link generated version resources to one materialisation activity."
  ],
  "deliberatelyExcluded": [
    "geometry",
    "tessellations",
    "full ifcOWL",
    "unallowlisted property sets",
    "reservations",
    "actor links",
    "institutional data",
    "IDS XML",
    "SHACL results",
    "credentials",
    "filesystem paths"
  ]
}
