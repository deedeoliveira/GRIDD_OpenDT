# Configuração do Apache Jena Fuseki para o OSWADT (Prompt 5A).
#
# Dois datasets DELIBERADAMENTE separados (nunca partilhar dados entre eles):
#   /oswadt-dev  — desenvolvimento local, persistente (TDB2 em run/databases/)
#   /oswadt-test — smoke/integração, em memória (perde tudo ao reiniciar)
#
# Endpoints por dataset:
#   .../query  — SPARQL 1.1 Query
#   .../update — SPARQL 1.1 Update
#   .../data   — SPARQL 1.1 Graph Store Protocol (leitura/escrita de named graphs)
#
# Nunca colocar dados de produção aqui; ver documentation/audit/PROMPT5A_GRAPH.md.

PREFIX :        <#>
PREFIX fuseki:  <http://jena.apache.org/fuseki#>
PREFIX rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX tdb2:    <http://jena.apache.org/2016/tdb#>
PREFIX ja:      <http://jena.hpl.hp.com/2005/11/Assembler#>

:service_dev rdf:type fuseki:Service ;
    fuseki:name "oswadt-dev" ;
    fuseki:endpoint [ fuseki:operation fuseki:query  ; fuseki:name "query"  ] ;
    fuseki:endpoint [ fuseki:operation fuseki:update ; fuseki:name "update" ] ;
    fuseki:endpoint [ fuseki:operation fuseki:gsp-rw ; fuseki:name "data"   ] ;
    fuseki:dataset :dataset_dev .

:dataset_dev rdf:type tdb2:DatasetTDB2 ;
    tdb2:location "run/databases/oswadt-dev" .

:service_test rdf:type fuseki:Service ;
    fuseki:name "oswadt-test" ;
    fuseki:endpoint [ fuseki:operation fuseki:query  ; fuseki:name "query"  ] ;
    fuseki:endpoint [ fuseki:operation fuseki:update ; fuseki:name "update" ] ;
    fuseki:endpoint [ fuseki:operation fuseki:gsp-rw ; fuseki:name "data"   ] ;
    fuseki:dataset :dataset_test .

:dataset_test rdf:type ja:DatasetTxnMem .
