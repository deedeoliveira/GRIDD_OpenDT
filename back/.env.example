PORT=3001
DB_HOST='localhost'
DB_PORT=3336
DB_NAME='digital_twin'
DB_USER=<username>
DB_PASSWORD=<password>
IFCOPENSHELL_FLASK_API_ROUTE="http://localhost:3002/api"
SENSORS_API_ROUTE="http://localhost:3001/api/sensor"

# Providers das políticas de reserva (ver back/policies/policyProvider.ts)
RESERVABILITY_POLICY_PROVIDER=legacy
RESERVATION_VALIDATION_PROVIDER=legacy

# Provider da identidade dos espaços (ver back/identity/spaceIdentityProvider.ts)
SPACE_IDENTITY_PROVIDER=pset-space-common-reference

# Providers do Prompt 4 (identidade de ativos, classificação, requisitos IFC)
ASSET_IDENTITY_PROVIDER=ifc-tag-serial-guid
EQUIPMENT_CLASSIFIER_PROVIDER=project-profile
MODEL_REQUIREMENTS_PROVIDER=project-profile-v1

# ------------------------------------------------------------------
# Grafo semântico (Prompt 5A) — OPCIONAL: sem estas variáveis a aplicação
# funciona normalmente; só as operações explícitas de grafo ficam indisponíveis.
# Serviço local: infrastructure/graph/ (Apache Jena Fuseki 5.6.0, porta 3030).
# Credenciais abaixo são de DESENVOLVIMENTO LOCAL (documentadas no shiro.ini);
# nunca usar credenciais reais neste ficheiro.
# ------------------------------------------------------------------
GRAPH_PROVIDER=fuseki
GRAPH_QUERY_ENDPOINT="http://localhost:3030/oswadt-dev/query"
GRAPH_UPDATE_ENDPOINT="http://localhost:3030/oswadt-dev/update"
GRAPH_DATA_ENDPOINT="http://localhost:3030/oswadt-dev/data"
GRAPH_USERNAME=admin
GRAPH_PASSWORD=<dev password — ver infrastructure/graph/config/shiro.ini>
GRAPH_REQUEST_TIMEOUT_MS=10000
GRAPH_BASE_URI="http://oswadt.local/id"

# Governed semantic artifact loading (local CLI only; never automatic startup).
# Keep disabled by default. Production requires an explicit true opt-in and the
# existing production-safe GRAPH_* base/credential guards.
SEMANTIC_ARTIFACT_LOADING_ENABLED=false
SEMANTIC_ARTIFACT_ROOT="../semantic/artifacts"
SEMANTIC_ARTIFACT_PUBLIC_MANIFEST="semantic-artifacts-public-manifest.json"

# Read-only institutional context and synthetic demonstrator (Prompt 7B2).
# Both features and all seeds are disabled by default. These settings reuse
# GRAPH_* and the Semantic Artifact Registry; no graph URI is client supplied.
INSTITUTIONAL_GRAPH_ENABLED=false
INSTITUTIONAL_DEMO_MODE=false
INSTITUTIONAL_ONTOLOGY_FAMILY_KEY="uminho-institutional-ontology"
INSTITUTIONAL_DATASET_FAMILY_KEY="uminho-institutional-synthetic-data"
INSTITUTIONAL_BRIDGE_FAMILY_KEY="project-institutional-bridge"

# IDS-based IFC information-requirement validation (Prompt 7C).
# Disabled by default; demo preparation explicitly uses required mode locally.
IDS_VALIDATION_ENABLED=false
IDS_VALIDATION_MODE=disabled
IDS_PROFILE_FAMILY_KEY="oswadt-ifc4-model-requirements"
IDS_DEMO_MODE=false
IDS_VALIDATION_TIMEOUT_MS=30000
# Optional when the project venv is not at back/python/venv/Scripts/python.exe.
# IDS_PYTHON_EXECUTABLE="C:/path/to/project/venv/Scripts/python.exe"

# Controlled model intake and minimal IFC-to-RDF materialisation (Prompt 7D).
# Disabled by default. The local walkthrough explicitly uses required mode.
MODEL_INTAKE_WORKSPACE_ENABLED=false
TEMPORARY_IDS_UPLOAD_ENABLED=false
IFC_RDF_MATERIALISATION_ENABLED=false
IFC_RDF_MATERIALISATION_MODE=disabled
IFC_RDF_MAPPING_FAMILY_KEY="oswadt-ifc4-minimal-rdf-mapping"
MODEL_INTAKE_MAX_IFC_BYTES=52428800
MODEL_INTAKE_MAX_IDS_BYTES=2097152
MODEL_INTAKE_RUN_TTL_MS=1800000

# Governed SHACL execution (Prompt 7E). Disabled by default.
SHACL_VALIDATION_ENABLED=false
SHACL_VALIDATION_MODE=disabled
SHACL_MODEL_SHAPES_FAMILY_KEY="oswadt-model-rdf-structural-shapes"
TEMPORARY_SHAPES_UPLOAD_ENABLED=false
SHACL_VALIDATION_TIMEOUT_MS=30000

# Cross-domain reservation evidence (Prompt 7F). Shadow is the only enabled
# semantic mode in this release; SQL remains temporal availability authority.
SEMANTIC_EVIDENCE_ENABLED=false
SEMANTIC_ELIGIBILITY_MODE=disabled
SEMANTIC_ELIGIBILITY_POLICY_FAMILY_KEY="project-reservation-eligibility-shadow"
SEMANTIC_EVIDENCE_DEMO_MODE=false
SEMANTIC_EVIDENCE_MAX_AGE_SECONDS=900
# Current local development identity for /student; it is not authentication.
CURRENT_APPLICATION_ACTOR_KEY="pg202404"
SEMANTIC_EVIDENCE_DEMO_CURRENT_ACTOR_LINK_ENABLED=false
# Optional only when it exactly matches CURRENT_APPLICATION_ACTOR_KEY.
# SEMANTIC_EVIDENCE_DEMO_CURRENT_ACTOR_KEY="pg202404"

# Prompt 7G: persistent local synthetic sessions. Never production authentication.
APPLICATION_IDENTITY_ENABLED=false
APPLICATION_IDENTITY_MODE=disabled
APPLICATION_SESSION_COOKIE_NAME="oswadt_local_session"
APPLICATION_SESSION_TTL_SECONDS=3600
LOCAL_SYNTHETIC_LOGIN_ENABLED=false
