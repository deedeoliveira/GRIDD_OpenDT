PORT=3001
DB_HOST='localhost'
DB_PORT=3336
DB_NAME='digital_twin'
DB_USER=<username>
DB_PASSWORD=<password>
IFCOPENSHELL_FLASK_API_ROUTE="http://localhost:3002/api"
SENSORS_API_ROUTE="http://localhost:3001/api/sensor"

# Providers das políticas de reserva (ver back/policies/policyProvider.ts)
RESERVABILITY_POLICY_PROVIDER=legacy
RESERVATION_VALIDATION_PROVIDER=legacy

# Provider da identidade dos espaços (ver back/identity/spaceIdentityProvider.ts)
SPACE_IDENTITY_PROVIDER=pset-space-common-reference

# Providers do Prompt 4 (identidade de ativos, classificação, requisitos IFC)
ASSET_IDENTITY_PROVIDER=ifc-tag-serial-guid
EQUIPMENT_CLASSIFIER_PROVIDER=project-profile
MODEL_REQUIREMENTS_PROVIDER=project-profile-v1

# ------------------------------------------------------------------
# Grafo semântico (Prompt 5A) — OPCIONAL: sem estas variáveis a aplicação
# funciona normalmente; só as operações explícitas de grafo ficam indisponíveis.
# Serviço local: infrastructure/graph/ (Apache Jena Fuseki 5.6.0, porta 3030).
# Credenciais abaixo são de DESENVOLVIMENTO LOCAL (documentadas no shiro.ini);
# nunca usar credenciais reais neste ficheiro.
# ------------------------------------------------------------------
GRAPH_PROVIDER=fuseki
GRAPH_QUERY_ENDPOINT="http://localhost:3030/oswadt-dev/query"
GRAPH_UPDATE_ENDPOINT="http://localhost:3030/oswadt-dev/update"
GRAPH_DATA_ENDPOINT="http://localhost:3030/oswadt-dev/data"
GRAPH_USERNAME=admin
GRAPH_PASSWORD=<dev password — ver infrastructure/graph/config/shiro.ini>
GRAPH_REQUEST_TIMEOUT_MS=10000
GRAPH_BASE_URI="http://oswadt.local/id"

# Governed semantic artifact loading (local CLI only; never automatic startup).
# Keep disabled by default. Production requires an explicit true opt-in and the
# existing production-safe GRAPH_* base/credential guards.
SEMANTIC_ARTIFACT_LOADING_ENABLED=false
SEMANTIC_ARTIFACT_ROOT="../semantic/artifacts"
SEMANTIC_ARTIFACT_PUBLIC_MANIFEST="semantic-artifacts-public-manifest.json"
